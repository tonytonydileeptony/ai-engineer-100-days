def _find_duplicates(nums):
     seen=set()
     duplicates=set()
     for num in nums:
          if num in seen :
               duplicates.add(num)
          else:
               seen.add(num)
     return duplicates

def main():
   nums  =[1,1,2,3,4,5,6,6]
   print(_find_duplicates(nums))

if __name__ == "__main__":
    main()
    
  
          